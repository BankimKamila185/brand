{
  "services": {
    "frontend": {
      "root": ".",
      "framework": "nextjs"
    },
    "backend": {
      "root": "backend",
      "entrypoint": "src/server.ts"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": {
        "service": "backend",
        "path": "/api/$1"
      }
    },
    {
      "source": "/health",
      "destination": {
        "service": "backend",
        "path": "/health"
      }
    }
  ]
}
