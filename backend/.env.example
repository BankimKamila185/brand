# ─────────────────────────────────────────────────────────────────
# Tevar Backend — Environment Variables
# Copy this to backend/.env and fill in your values
# NEVER commit backend/.env to git
# ─────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://tevar_user:tevar_pass@localhost:5432/tevar?schema=public

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT (generate with: openssl rand -hex 32) ────────────────────
JWT_SECRET=your_super_secret_jwt_key_at_least_32_chars_long
JWT_REFRESH_SECRET=your_super_secret_refresh_key_at_least_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Email (SMTP) ─────────────────────────────────────────────────
# For development, use https://ethereal.email (free)
# For production: Resend, SendGrid, or AWS SES
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM=Tevar <noreply@tevar.in>

# ── Cloudinary ───────────────────────────────────────────────────
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Razorpay ─────────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ── Frontend ─────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Security ─────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── Docker Compose ────────────────────────────────────────────────
# (used by docker-compose.yml, not the app directly)
POSTGRES_DB=tevar
POSTGRES_USER=tevar_user
POSTGRES_PASSWORD=your_postgres_password_here
REDIS_PASSWORD=your_redis_password_here

# ── Firebase Admin ────────────────────────────────────────────────
FIREBASE_DATABASE_URL=https://your-project-id.firebaseio.com
# Provide EITHER a single JSON string containing the Service Account key:
FIREBASE_SERVICE_ACCOUNT_KEY=
# OR individual Service Account fields:
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
